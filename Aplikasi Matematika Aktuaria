def persamaan_nilai():

    print("\n===================================")
    print("           PERSAMAAN NILAI")
    print("===================================")

    P1 = input_angka("Masukkan nilai pertama")
    i = input_angka("Masukkan tingkat bunga")
    n1 = input_angka("Masukkan waktu pertama")
    n2 = int(input_angka("Masukkan waktu kedua"))

