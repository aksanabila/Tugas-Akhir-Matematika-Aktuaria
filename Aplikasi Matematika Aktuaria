    print("\n========== HASIL ==========")
    print("Nilai ekuivalen     = Rp", round(P2, 2))
    print("===========================")

    lanjut()

# -------------------------------
# 15. EQUATION OF VALUE
# -------------------------------
def equation_of_value():

    print("\n===================================")
    print("           EQUATION OF VALUE")
    print("===================================")

    jumlah = int(input_angka("Masukkan jumlah arus kas"))
    i = input_angka("Masukkan tingkat bunga")
    focal = input_angka("Masukkan waktu fokus")

    total = 0

    for k in range(1, jumlah + 1):

        cashflow = input_angka(f"Masukkan arus kas ke-{k}")
        waktu = input_angka(f"Masukkan waktu arus kas ke-{k}")

        nilai = cashflow * ((1 + i) ** (focal - waktu))
        total += nilai

    print("\n========== HASIL ==========")
    print("Nilai ekuivalen     = Rp", round(total, 2))
    print("===========================")

    lanjut()

# -------------------------------
# 16. NPV PROYEK
# -------------------------------
def npv_proyek():

    print("\n===================================")
    print("           NPV PROYEK")
    print("===================================")

    investasi = input_angka("Masukkan investasi awal")
    i = input_angka("Masukkan required return")
    tahun = int(input_angka("Masukkan jumlah tahun"))

    total = 0

    for t in range(1, tahun + 1):

        cashflow = input_angka(f"Masukkan arus kas tahun ke-{t}")
        pv = cashflow / ((1 + i) ** t)
        total += pv

    npv = total - investasi

    print("\n========== HASIL ==========")
    print("NPV                  = Rp", round(npv, 2))
    print("===========================")

    lanjut()

