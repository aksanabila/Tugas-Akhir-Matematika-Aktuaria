# -------------------------------
# 1. BUNGA SEDERHANA
# -------------------------------
def bunga_sederhana():

    print("\n===================================")
    print("      MENGHITUNG BUNGA SEDERHANA")
    print("===================================")

    P = input_angka("Masukkan modal awal")
    i = input_angka("Masukkan tingkat bunga")
    t = input_angka("Masukkan waktu (tahun)")

    bunga = P * i * t
    A = P * (1 + i * t)

    print("\n========== HASIL ==========")
    print("Modal awal            = Rp", round(P, 2))
    print("Bunga                 = Rp", round(bunga, 2))
    print("Jumlah akhir          = Rp", round(A, 2))
    print("===========================")

    lanjut()

# -------------------------------
# 2. BUNGA MAJEMUK
# -------------------------------
def bunga_majemuk():

    print("\n===================================")
    print("       MENGHITUNG BUNGA MAJEMUK")
    print("===================================")

    P = input_angka("Masukkan modal awal")
    i = input_angka("Masukkan tingkat bunga")
    n = int(input_angka("Masukkan jumlah tahun"))

    A = P * (1 + i) ** n
    bunga = A - P

    print("\n========== HASIL ==========")
    print("Modal awal            = Rp", round(P, 2))
    print("Bunga                 = Rp", round(bunga, 2))
    print("Jumlah akhir          = Rp", round(A, 2))
    print("===========================")

    lanjut()

# -------------------------------
# 3. BUNGA MAJEMUK m-KALI
# -------------------------------
def bunga_majemuk_m():

    print("\n===================================")
    print("      BUNGA MAJEMUK m-KALI")
    print("===================================")

    P = input_angka("Masukkan modal awal")
    i = input_angka("Masukkan bunga nominal")
    m = int(input_angka("Masukkan frekuensi konversi"))
    t = input_angka("Masukkan waktu (tahun)")

    A = P * (1 + i / m) ** (m * t)

    print("\n========== HASIL ==========")
    print("Nilai akumulasi      = Rp", round(A, 2))
    print("===========================")

    lanjut()

# -------------------------------
# 4. TINGKAT BUNGA
# -------------------------------
def tingkat_bunga():

    print("\n===================================")
    print("         MENGHITUNG TINGKAT BUNGA")
    print("===================================")

    P = input_angka("Masukkan modal awal")
    A = input_angka("Masukkan jumlah akhir")
    n = int(input_angka("Masukkan jumlah tahun"))

    i = ((A / P) ** (1 / n)) - 1

    print("\n========== HASIL ==========")
    print("Tingkat bunga       =", round(i * 100, 4), "%")
    print("===========================")

    lanjut()

