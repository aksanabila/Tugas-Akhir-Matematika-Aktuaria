# 25. SISA UTANG
# -------------------------------
def sisa_utang():

    print("\n===================================")
    print("             SISA UTANG")
    print("===================================")

    pinjaman = input_angka("Masukkan jumlah pinjaman")
    i = input_angka("Masukkan tingkat bunga")
    n = int(input_angka("Masukkan jumlah periode"))
    k = int(input_angka("Masukkan periode yang telah dibayar"))

    an = (1 - (1 + i) ** (-n)) / i
    R = pinjaman / an

    sisa = R * ((1 - (1 + i) ** -(n - k)) / i)

    print("\n========== HASIL ==========")
    print("Sisa utang         = Rp", round(sisa, 2))
    print("===========================")

    lanjut()

