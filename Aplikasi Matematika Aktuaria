    print("=" * 78)

    for t in range(1, n + 1):

        bunga = sisa * i
        pokok = R - bunga
        sisa -= pokok

        if sisa < 0:
            sisa = 0

        print(
            f"{t:<8} | "
            f"{R:<15,.2f} | "
            f"{bunga:<15,.2f} | "
            f"{pokok:<15,.2f} | "
            f"{sisa:<15,.2f}"
        )

