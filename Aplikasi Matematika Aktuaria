# -------------------------------
# 10. ANUITAS JATUH TEMPO
# -------------------------------
def anuitas_jatuh_tempo():
    print("\n===================================")
    print("      MENGHITUNG ANUITAS JATUH TEMPO")
    print("===================================")

    i = float(input("Masukkan tingkat bunga       : "))
    n = int(input("Masukkan jumlah periode      : "))

    an_due = ((1 - (1 + i) ** (-n)) / i) * (1 + i)

    print("\n========== HASIL ==========")
    print("Anuitas jatuh tempo =", round(an_due, 4))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 11. ANUITAS PEMBAYARAN m KALI
# -------------------------------
def anuitas_m():
    print("\n===================================")
    print("   ANUITAS PEMBAYARAN m KALI")
    print("===================================")

    R = float(input("Masukkan pembayaran          : "))
    i = float(input("Masukkan bunga tahunan       : "))
    m = int(input("Masukkan pembayaran/tahun    : "))
    n = int(input("Masukkan jumlah tahun        : "))

    im = i / m
    PV = R * ((1 - (1 + im) ** (-m * n)) / im)

    print("\n========== HASIL ==========")
    print("Nilai anuitas       = Rp", round(PV, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 12. ANUITAS PINJAMAN
# -------------------------------
def anuitas_pinjaman():
    print("\n===================================")
    print("   ANUITAS PINJAMAN")
    print("===================================")

    pinjaman = float(input("Masukkan jumlah pinjaman : "))
    i = float(input("Masukkan bunga           : "))
    n = int(input("Masukkan lama pinjaman   : "))

    an = (1 - (1 + i) ** (-n)) / i
    R = pinjaman / an
    total_bayar = R * n
    total_bunga = total_bayar - pinjaman

    print("\n========== HASIL ==========")
    print("Cicilan per tahun = Rp", round(R, 2))
    print("Total pembayaran  = Rp", round(total_bayar, 2))
    print("Total bunga       = Rp", round(total_bunga, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 13. ANUITAS DUE
# -------------------------------
def anuitas_due():
    print("\n===================================")
    print("              ANUITAS DUE")
    print("===================================")

    pembayaran = float(input("Masukkan pembayaran tahunan : "))
    i = float(input("Masukkan bunga              : "))
    n = int(input("Masukkan jumlah tahun       : "))

    an_due = ((1 - (1 + i) ** (-n)) / i) * (1 + i)
    PV = pembayaran * an_due

    print("\n========== HASIL ==========")
    print("Nilai sekarang anuitas due = Rp", round(PV, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 14. NPV PROYEK
# -------------------------------
def npv_proyek():
    print("\n===================================")
    print("NET PRESENT VALUE (NPV)")
    print("===================================")

    investasi_awal = float(input("Masukkan investasi awal : "))
    i = float(input("Masukkan required return: "))
    tahun = int(input("Masukkan jumlah tahun arus kas: "))

    total_pv = 0

    for t in range(1, tahun + 1):
        cashflow = float(input(f"Arus kas tahun ke-{t}: "))
        pv = cashflow / ((1 + i) ** t)
        total_pv += pv

    npv = total_pv - investasi_awal

    print("\n========== HASIL ==========")
    print("Total Present Value = Rp", round(total_pv, 2))
    print("NPV                 = Rp", round(npv, 2))
    print("===========================")

    if npv > 0:
        print("Kesimpulan: Proyek LAYAK dijalankan")
    elif npv < 0:
        print("Kesimpulan: Proyek TIDAK layak")
    else:
        print("Kesimpulan: Proyek impas")
    
    hitung_mundur()

