# -------------------------------
# 23. MENCARI JUMLAH PERIODE
# -------------------------------
def jumlah_periode():

    print("\n===================================")
    print("         MENCARI JUMLAH PERIODE")
    print("===================================")

    pinjaman = input_angka("Masukkan jumlah pinjaman")
    R = input_angka("Masukkan pembayaran anuitas")
    i = input_angka("Masukkan tingkat bunga")

    n = -math.log(1 - (pinjaman * i / R)) / math.log(1 + i)

    print("\n========== HASIL ==========")
    print("Jumlah periode     =", round(n, 4))
    print("===========================")

    lanjut()

