# -------------------------------
# 21. ANUITAS PEMBAYARAN m-KALI
# -------------------------------
def anuitas_m():

    print("\n===================================")
    print("      ANUITAS PEMBAYARAN m-KALI")
    print("===================================")

    R = input_angka("Masukkan pembayaran")
    i = input_angka("Masukkan bunga tahunan")
    m = int(input_angka("Masukkan pembayaran per tahun"))
    n = int(input_angka("Masukkan jumlah tahun"))

    im = i / m

    PV = R * ((1 - (1 + im) ** (-m * n)) / im)

    print("\n========== HASIL ==========")
    print("Nilai anuitas      = Rp", round(PV, 2))
    print("===========================")

    lanjut()

