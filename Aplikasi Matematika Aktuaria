# 1. BUNGA SEDERHANA
# -------------------------------
def bunga_sederhana():
    print("\n===================================")
    print("      MENGHITUNG BUNGA SEDERHANA")
    print("===================================")

    P = float(input("Masukkan pokok/modal awal                                       : "))
    i = float(input("Masukkan tingkat bunga efektif per tahun (bilangan desimal)     : "))
    t = float(input("Masukkan lama investasi (dalam tahun)                           : "))

    A = P * (1 + i * t)
    bunga = A - P

    print("\n========== HASIL ==========")
    print("Modal awal          = Rp", round(P, 2))
    print("Total bunga         = Rp", round(bunga, 2))
    print("Jumlah akhir        = Rp", round(A, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 2. BUNGA MAJEMUK
# -------------------------------
def bunga_majemuk():
    print("\n===================================")
    print("       MENGHITUNG BUNGA MAJEMUK")
    print("===================================")

    P = float(input("Masukkan pokok/modal awal                                       : "))
    i = float(input("Masukkan tingkat bunga efektif per tahun (bilangan desimal)     : "))
    n = int(input("Masukkan jumlah tahun                                             : "))

    A = P * (1 + i) ** n
    bunga = A - P

    print("\n========== HASIL ==========")
    print("Modal awal          = Rp", round(P, 2))
    print("Total bunga         = Rp", round(bunga, 2))
    print("Jumlah akhir        = Rp", round(A, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 3. Tingkat Bunga
# -------------------------------
def tingkat_bunga():
    print("\n===================================")
    print("         MENGHITUNG TINGKAT BUNGA")
    print("===================================")

    P = float(input("Masukkan pokok/modal awal                                       : "))
    A = float(input("Masukkan jumlah akhir                                           : "))
    n = int(input("Masukkan jumlah tahun                                             : "))

    bunga = ((A / P) ** (1 / n)) - 1
    persen = bunga * 100

    print("\n========== HASIL ==========")
    print("Tingkat bunga =", round(persen, 2), "%")
    print("===========================")

    hitung_mundur()

# -------------------------------
# 4. PRESENT VALUE
# -------------------------------
def present_value():
    print("\n===================================")
    print("        MENGHITUNG PRESENT VALUE")
    print("===================================")

    FV = float(input("Masukkan future value        : "))
    i = float(input("Masukkan tingkat bunga       : "))
    n = int(input("Masukkan jumlah tahun        : "))

    PV = FV / ((1 + i) ** (-n))

    print("\n========== HASIL ==========")
    print("Future Value        = Rp", round(FV, 2))
    print("Present Value       = Rp", round(PV, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 5. FUTURE VALUE
# -------------------------------
def future_value():
    print("\n===================================")
    print("         MENGHITUNG FUTURE VALUE")
    print("===================================")

    PV = float(input("Masukkan present value       : "))
    i = float(input("Masukkan tingkat bunga       : "))
    n = int(input("Masukkan jumlah tahun        : "))

    FV = PV * ((1 + i) ** n)

    print("\n========== HASIL ==========")
    print("Present Value       = Rp", round(PV, 2))
    print("Future Value        = Rp", round(FV, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 6. DISKONTO NOMINAL
# -------------------------------
def diskonto_nominal():
    print("\n===================================")
    print("        MENGHITUNG DISKONTO")
    print("===================================")

    FV = float(input("Masukkan future value        : "))
    d = float(input("Masukkan tingkat diskonto    : "))
    t = float(input("Masukkan waktu               : "))

    PV = FV * (1 - d * t)
    diskon = FV - PV

    print("\n========== HASIL ==========")
    print("Future Value        = Rp", round(FV, 2))
    print("Nilai diskonto      = Rp", round(diskon, 2))
    print("Present Value       = Rp", round(PV, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 7. PERSAMAAN NILAI
# -------------------------------
def persamaan_nilai():
    print("\n===================================")
    print("        MENGHITUNG PERSAMAAN NILAI")
    print("===================================")

    P1 = float(input("Masukkan nilai pertama       : "))
    i = float(input("Masukkan tingkat bunga       : "))
    n1 = int(input("Masukkan waktu pertama       : "))
    n2 = int(input("Masukkan waktu kedua         : "))

    P2 = (P1 * ((1 + i) ** n1)) / ((1 + i) ** n2)

    print("\n========== HASIL ==========")
    print("Nilai ekuivalen = Rp", round(P2, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 8. ANUITAS UMUM
# -------------------------------
def anuitas_umum():
    print("\n===================================")
    print("       MENGHITUNG ANUITAS UMUM")
    print("===================================")

    R = float(input("Masukkan pembayaran          : "))
    i = float(input("Masukkan tingkat bunga       : "))
    n = int(input("Masukkan jumlah periode      : "))

    PV = R * ((1 - (1 + i) ** (-n)) / i)

    print("\n========== HASIL ==========")
    print("Present Value       = Rp", round(PV, 2))
    print("===========================")

    hitung_mundur()

# -------------------------------
# 9. ANUITAS PASTI
# -------------------------------
def anuitas_pasti():
    print("\n===================================")
    print("         MENGHITUNG ANUITAS PASTI")
    print("===================================")

    i = float(input("Masukkan tingkat bunga       : "))
    n = int(input("Masukkan jumlah periode      : "))

