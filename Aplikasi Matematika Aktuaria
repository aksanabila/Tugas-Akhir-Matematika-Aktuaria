# 27. YIELD RATE
# -------------------------------
def yield_rate():

    print("\n===================================")
    print("              YIELD RATE")
    print("===================================")

    investasi = input_angka("Masukkan investasi awal")
    cash1 = input_angka("Masukkan cashflow pertama")
    t1 = int(input_angka("Masukkan waktu cashflow pertama"))
    cash2 = input_angka("Masukkan cashflow kedua")
    t2 = int(input_angka("Masukkan waktu cashflow kedua"))

    i = 0.01

    while i < 1:

        pv = cash1 * (1 + i) ** (-t1) + cash2 * (1 + i) ** (-t2)

        if abs(pv - investasi) < 1000:
            break

        i += 0.0001

    print("\n========== HASIL ==========")
    print("Yield Rate        =", round(i * 100, 4), "%")
    print("===========================")

    lanjut()

