# -------------------------------
# 12. FORCE OF INTEREST
# -------------------------------
def force_interest():

    print("\n===================================")
    print("           FORCE OF INTEREST")
    print("===================================")

    P = input_angka("Masukkan modal awal")
    delta = input_angka("Masukkan force of interest")
    t = input_angka("Masukkan waktu")

    A = P * math.exp(delta * t)

    print("\n========== HASIL ==========")
    print("Nilai akumulasi      = Rp", round(A, 2))
    print("===========================")

    lanjut()

# -------------------------------
